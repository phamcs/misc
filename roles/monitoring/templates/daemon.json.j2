{
  "data-root": "/var/lib/docker",
  "log-driver": "loki",
  "log-opts": {
    "loki-url": "http://loki:3100/loki/api/v1/push",
    "loki-batch-size": "400",
    "loki-retries": "5",
    "loki-max-backoff": "800ms",
    "loki-timeout": "1s",
    "loki-external-labels": "job=docker,host={{{{.Name}}}}"
  }
}
